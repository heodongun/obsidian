{
  "name": "obsidian-wiki-viewer",
  "private": true,
  "version": "0.1.0",
  "scripts": {
    "dev": "concurrently -k -n content,ui -c cyan,green \"npm:content:watch\" \"vite --config wiki/vite.config.ts\"",
    "build": "npm run content:build && vite build --config wiki/vite.config.ts",
    "deploy": "wrangler deploy",
    "preview": "vite preview --config wiki/vite.config.ts",
    "check": "tsc --noEmit",
    "content:build": "node scripts/build-content.cjs",
    "content:watch": "node scripts/build-content.cjs --watch",
    "sync:velog": "node scripts/sync-velog.cjs"
  },
  "dependencies": {
    "@fontsource/ibm-plex-mono": "^5.2.7",
    "@fontsource/ibm-plex-sans-kr": "^5.2.8",
    "@fontsource/newsreader": "^5.2.7",
    "chokidar": "^4.0.3",
    "fast-glob": "^3.3.3",
    "fuse.js": "^7.1.0",
    "github-slugger": "^2.0.0",
    "gray-matter": "^4.0.3",
    "hast-util-to-string": "^3.0.1",
    "katex": "^0.16.11",
    "playwright": "^1.53.2",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "react-markdown": "^10.1.0",
    "react-router-dom": "^7.6.2",
    "rehype-highlight": "^7.0.2",
    "rehype-katex": "^7.0.1",
    "rehype-raw": "^7.0.0",
    "rehype-slug": "^6.0.0",
    "remark-gfm": "^4.0.1",
    "remark-math": "^6.0.0",
    "unist-util-visit": "^5.0.0"
  },
  "devDependencies": {
    "@types/node": "^24.0.1",
    "@types/react": "^19.1.8",
    "@types/react-dom": "^19.1.6",
    "@vitejs/plugin-react": "^4.5.2",
    "concurrently": "^9.1.2",
    "typescript": "^5.8.3",
    "vite": "^6.3.5",
    "wrangler": "^4.76.0"
  }
}
